@page "/login"
@layout EmptyLayout
@inject AuthService AuthService
@inject NavigationManager Navigation
@using admin_blazor.Models

<div class="min-vh-100 d-flex align-items-center justify-content-center p-4"
     style="background: linear-gradient(135deg, #2563eb 0%, #9333ea 100%);">
    <div class="card shadow-lg border-0 rounded-4 w-100" style="max-width: 400px;">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <h1 class="h2 fw-bold text-dark">Macaw Admin</h1>
                <p class="text-secondary mt-2">Painel Administrativo</p>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mb-4" role="alert">
                    @errorMessage
                </div>
            }

            <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label text-secondary fw-medium small">Email</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-envelope text-secondary"></i>
                        </span>
                        <InputText @bind-Value="loginModel.Email"
                                  class="form-control bg-light border-start-0 ps-0"
                                  placeholder="admin@macaw.com" required />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label text-secondary fw-medium small">Senha</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-lock text-secondary"></i>
                        </span>
                        <InputText @bind-Value="loginModel.Password"
                                  type="password"
                                  class="form-control bg-light border-start-0 ps-0"
                                  placeholder="••••••••" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-3 @(loading ? "disabled" : "")">
                    @if (loading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    }
                    Entrar
                </button>
            </EditForm>

            <p class="text-center text-secondary small mt-4 pt-2">
                © 2026 Macaw English School.
            </p>
        </div>
    </div>
</div>

@code {
    private LoginRequest loginModel = new();
    private string? errorMessage;
    private bool loading;

    private async Task HandleLogin()
    {
        loading = true;
        errorMessage = null;

        try
        {
            var success = await AuthService.Login(loginModel.Email, loginModel.Password);
            if (success)
            {
                Navigation.NavigateTo("dashboard");
            }
            else
            {
                errorMessage = "Email ou senha inválidos.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Erro ao tentar realizar login. Tente novamente.";
        }
        finally
        {
            loading = false;
        }
    }
}
