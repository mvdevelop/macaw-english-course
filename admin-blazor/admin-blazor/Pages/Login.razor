@page "/login"
@layout EmptyLayout
@inject AuthService AuthService
@inject NavigationManager Navigation
@using admin_blazor.Models

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <h1 class="login-title">🦜 Macaw Admin</h1>
            <p class="login-subtitle">Painel Administrativo</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">
                @errorMessage
                <button class="alert-close" @onclick="() => errorMessage = null">&times;</button>
            </div>
        }

        <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label class="form-label">Email</label>
                <div class="input-icon">
                    <span class="icon">📧</span>
                    <InputText @bind-Value="loginModel.Email"
                              class="form-control"
                              placeholder="admin@macaw.com" required />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Senha</label>
                <div class="input-icon">
                    <span class="icon">🔒</span>
                    <InputText @bind-Value="loginModel.Password"
                              type="password"
                              class="form-control"
                              placeholder="••••••••" required />
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-full @(loading ? "disabled" : "")">
                @if (loading)
                {
                    <span class="spinner"></span>
                }
                Entrar
            </button>
        </EditForm>

        <p class="login-footer">© 2026 Macaw English School.</p>
    </div>
</div>

@code {
    private LoginRequest loginModel = new();
    private string? errorMessage;
    private bool loading;

    private async Task HandleLogin()
    {
        loading = true;
        errorMessage = null;

        var (success, error) = await AuthService.Login(loginModel.Email, loginModel.Password);

        if (success)
        {
            Navigation.NavigateTo("/", forceLoad: true);
        }
        else
        {
            errorMessage = error ?? "Email ou senha inválidos.";
        }

        loading = false;
    }
}
