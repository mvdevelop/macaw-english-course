@page "/dashboard"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject AuthService AuthService
@inject NavigationManager Navigation
@using System.Security.Claims

<div class="min-vh-100 bg-light">
    <!-- Header -->
    <header class="bg-white shadow-sm border-bottom">
        <div class="container-xl py-3 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 fw-bold text-dark mb-0">Macaw Admin</h1>
                <p class="text-secondary small mb-0">Bem-vindo, @userName</p>
            </div>
            <button @onclick="HandleLogout" class="btn btn-outline-danger d-flex align-items-center gap-2">
                <i class="bi bi-box-arrow-right"></i>
                Sair
            </button>
        </div>
    </header>

    <!-- Main Content -->
    <main class="container-xl py-5">
        <!-- Stats Cards -->
        <div class="row g-4 mb-5">
            <div class="col-12 col-md-4">
                <div class="card border-0 shadow-sm rounded-3 p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-secondary small fw-medium mb-1">Total de Cursos</p>
                            <p class="h2 fw-bold text-dark mb-0">0</p>
                        </div>
                        <div class="bg-primary-subtle p-3 rounded-circle">
                            <i class="bi bi-book text-primary fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-4">
                <div class="card border-0 shadow-sm rounded-3 p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-secondary small fw-medium mb-1">Total de Alunos</p>
                            <p class="h2 fw-bold text-dark mb-0">0</p>
                        </div>
                        <div class="bg-success-subtle p-3 rounded-circle">
                            <i class="bi bi-people text-success fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-4">
                <div class="card border-0 shadow-sm rounded-3 p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-secondary small fw-medium mb-1">Total de Aulas</p>
                            <p class="h2 fw-bold text-dark mb-0">0</p>
                        </div>
                        <div class="bg-purple-subtle p-3 rounded-circle" style="background-color: #f3e8ff;">
                            <i class="bi bi-layers text-purple fs-3" style="color: #9333ea;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabs Content -->
        <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
            <div class="card-header bg-white border-bottom-0 p-0">
                <ul class="nav nav-tabs border-bottom px-4">
                    <li class="nav-item">
                        <button class="nav-link py-3 px-4 border-0 @(activeTab == "courses" ? "active border-bottom border-primary text-primary fw-bold" : "text-secondary")"
                                @onclick='() => activeTab = "courses"'>
                            Cursos
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link py-3 px-4 border-0 @(activeTab == "students" ? "active border-bottom border-primary text-primary fw-bold" : "text-secondary")"
                                @onclick='() => activeTab = "students"'>
                            Alunos
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link py-3 px-4 border-0 @(activeTab == "lessons" ? "active border-bottom border-primary text-primary fw-bold" : "text-secondary")"
                                @onclick='() => activeTab = "lessons"'>
                            Aulas
                        </button>
                    </li>
                </ul>
            </div>

            <div class="card-body p-5">
                @if (activeTab == "courses")
                {
                    <div class="fade-in">
                        <h2 class="h5 fw-bold text-dark mb-4">Gerenciar Cursos</h2>
                        <button class="btn btn-primary px-4 py-2 mb-4">+ Novo Curso</button>
                        <p class="text-secondary">Nenhum curso cadastrado ainda.</p>
                    </div>
                }
                else if (activeTab == "students")
                {
                    <div class="fade-in">
                        <h2 class="h5 fw-bold text-dark mb-4">Gerenciar Alunos</h2>
                        <button class="btn btn-success px-4 py-2 mb-4">+ Novo Aluno</button>
                        <p class="text-secondary">Nenhum aluno cadastrado ainda.</p>
                    </div>
                }
                else if (activeTab == "lessons")
                {
                    <div class="fade-in">
                        <h2 class="h5 fw-bold text-dark mb-4">Gerenciar Aulas</h2>
                        <button class="btn btn-dark px-4 py-2 mb-4" style="background-color: #9333ea; border-color: #9333ea;">+ Nova Aula</button>
                        <p class="text-secondary">Nenhuma aula cadastrada ainda.</p>
                    </div>
                }
            </div>
        </div>
    </main>
</div>

<style>
    .fade-in {
        animation: fadeIn 0.3s ease-in;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .nav-tabs .nav-link.active {
        border-bottom: 3px solid #0d6efd !important;
        background: transparent !important;
    }
</style>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private string? userName;
    private string activeTab = "courses";

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            userName = authState.User.Identity?.Name;
        }
    }

    private async Task HandleLogout()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("login");
    }
}
