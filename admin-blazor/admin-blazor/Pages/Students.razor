@page "/students"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject StudentService StudentService
@using admin_blazor.Models

<PageTitle>Alunos - Macaw Admin</PageTitle>

@if (!string.IsNullOrEmpty(notification))
{
    <div class="alert @(notificationType == "success" ? "alert-success" : "alert-danger")">
        @notification
        <button class="alert-close" @onclick="() => notification = null">&times;</button>
    </div>
}

<div class="toolbar">
    <p class="toolbar-count">@students.Count alunos cadastrados</p>
    <button class="btn btn-primary" @onclick="OpenCreate">
        + Novo Aluno
    </button>
</div>

<div class="content-card">
    @if (loading)
    {
        <p class="empty-state">Carregando...</p>
    }
    else if (students.Count == 0)
    {
        <p class="empty-state">Nenhum aluno encontrado.</p>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Telefone</th>
                        <th>Nível</th>
                        <th class="actions-col">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in students)
                    {
                        <tr>
                            <td><strong>@student.Name</strong></td>
                            <td>@student.Email</td>
                            <td>@student.Phone</td>
                            <td>@student.Level</td>
                            <td class="actions-col">
                                <button class="btn-icon btn-edit" @onclick="() => OpenEdit(student)" title="Editar">✏️</button>
                                <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(student)" title="Excluir">🗑️</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (showModal)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(isEditing ? "Editar Aluno" : "Novo Aluno")</h3>
                <button class="modal-close" @onclick="CloseModal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Nome</label>
                    <input class="form-control" @bind="form.Name" placeholder="Nome completo" />
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input class="form-control" type="email" @bind="form.Email" placeholder="email@exemplo.com" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Telefone</label>
                        <input class="form-control" @bind="form.Phone" placeholder="(11) 99999-9999" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Nível</label>
                        <select class="form-control" @bind="form.Level">
                            <option value="">Selecione</option>
                            <option value="Básico">Básico</option>
                            <option value="Intermediário">Intermediário</option>
                            <option value="Avançado">Avançado</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@(saving)">
                    @(saving ? "Salvando..." : "Salvar")
                </button>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal-backdrop" @onclick="() => showDeleteConfirm = false">
        <div class="modal modal-sm" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Confirmar Exclusão</h3>
                <button class="modal-close" @onclick="() => showDeleteConfirm = false">&times;</button>
            </div>
            <div class="modal-body">
                <p>Tem certeza que deseja excluir o aluno <strong>"@deleteTarget?.Name"</strong>?</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancelar</button>
                <button class="btn btn-danger" @onclick="Delete">Excluir</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Student> students = new();
    private bool loading = true;

    private bool showModal;
    private bool isEditing;
    private bool saving;
    private Student form = new();
    private string? editingId;

    private bool showDeleteConfirm;
    private Student? deleteTarget;

    private string? notification;
    private string? notificationType;

    protected override async Task OnInitializedAsync()
    {
        await LoadStudents();
    }

    private async Task LoadStudents()
    {
        loading = true;
        students = await StudentService.GetAllAsync();
        loading = false;
    }

    private void OpenCreate()
    {
        isEditing = false;
        editingId = null;
        form = new Student();
        showModal = true;
    }

    private void OpenEdit(Student student)
    {
        isEditing = true;
        editingId = student.Id;
        form = new Student
        {
            Id = student.Id,
            Name = student.Name,
            Email = student.Email,
            Phone = student.Phone,
            Level = student.Level
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        form = new();
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(form.Name)) return;

        saving = true;
        var result = isEditing && !string.IsNullOrEmpty(editingId)
            ? await StudentService.UpdateAsync(editingId, form)
            : await StudentService.CreateAsync(form);

        saving = false;
        if (result.success)
        {
            notification = isEditing ? "Aluno atualizado com sucesso!" : "Aluno criado com sucesso!";
            notificationType = "success";
            await LoadStudents();
        }
        else
        {
            notification = $"Erro: {result.error}";
            notificationType = "error";
        }
        CloseModal();
    }

    private void ConfirmDelete(Student student)
    {
        deleteTarget = student;
        showDeleteConfirm = true;
    }

    private async Task Delete()
    {
        if (deleteTarget == null) return;
        var result = await StudentService.DeleteAsync(deleteTarget.Id);
        showDeleteConfirm = false;
        deleteTarget = null;

        if (result.success)
        {
            notification = "Aluno excluído com sucesso!";
            notificationType = "success";
            await LoadStudents();
        }
        else
        {
            notification = $"Erro: {result.error}";
            notificationType = "error";
        }
    }
}
