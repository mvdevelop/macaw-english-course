@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject CourseService CourseService
@inject StudentService StudentService

<PageTitle>Dashboard - Macaw Admin</PageTitle>

<!-- Stats -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon bg-primary-subtle">📚</div>
        <div class="stat-body">
            <p class="stat-label">Total de Cursos</p>
            <p class="stat-value">@courses.Count</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon bg-success-subtle">👥</div>
        <div class="stat-body">
            <p class="stat-label">Total de Alunos</p>
            <p class="stat-value">@students.Count</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon bg-info-subtle">🎬</div>
        <div class="stat-body">
            <p class="stat-label">Total de Aulas</p>
            <p class="stat-value">0</p>
        </div>
    </div>
</div>

<!-- Recent -->
<div class="content-card">
    <h2 class="section-title">Cursos Recentes</h2>
    @if (courses.Count == 0)
    {
        <p class="empty-state">Nenhum curso cadastrado ainda. <NavLink href="/courses" class="link-action">Criar primeiro curso</NavLink></p>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Título</th>
                        <th>Nível</th>
                        <th>Preço</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in courses.Take(5))
                    {
                        <tr>
                            <td><strong>@course.Title</strong></td>
                            <td>@course.Level</td>
                            <td>R$ @course.Price.ToString("F2")</td>
                            <td>
                                <span class="badge @(course.IsActive ? "badge-success" : "badge-danger")">
                                    @(course.IsActive ? "Ativo" : "Inativo")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<admin_blazor.Models.Course> courses = new();
    private List<admin_blazor.Models.Student> students = new();

    protected override async Task OnInitializedAsync()
    {
        courses = await CourseService.GetAllAsync();
        students = await StudentService.GetAllAsync();
    }
}
