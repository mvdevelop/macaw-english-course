@page "/lessons"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject CourseService CourseService
@inject HttpClient Http
@using admin_blazor.Models

<PageTitle>Lições - Macaw Admin</PageTitle>

@if (!string.IsNullOrEmpty(notification))
{
    <div class="alert @(notificationType == "success" ? "alert-success" : "alert-danger")">
        @notification
        <button class="alert-close" @onclick="() => notification = null">&times;</button>
    </div>
}

<!-- Level selector -->
<div class="toolbar">
    <div class="flex items-center gap-3">
        <label class="text-sm font-medium text-gray-500">Nível:</label>
        <select class="form-control" style="width:auto" value="@selectedLevel" @onchange="OnLevelChanged">
            <option value="">Todos</option>
            @foreach (var lvl in Levels)
            {
                <option value="@lvl">@lvl</option>
            }
        </select>
    </div>
    <button class="btn btn-primary" @onclick="OpenCreate">+ Nova Lição</button>
</div>

<div class="content-card">
    @if (loading)
    {
        <p class="empty-state">Carregando...</p>
    }
    else if (lessons.Count == 0)
    {
        <p class="empty-state">Nenhuma lição encontrada. <a class="link-action" @onclick="OpenCreate">Criar primeira lição</a></p>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Nível</th>
                        <th>Módulo</th>
                        <th>Título</th>
                        <th>Ordem</th>
                        <th>Exercícios</th>
                        <th>Tempo</th>
                        <th>Status</th>
                        <th class="actions-col">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lesson in lessons)
                    {
                        <tr>
                            <td><span class="badge badge-primary">@lesson.LevelCode</span></td>
                            <td>@lesson.ModuleTitle</td>
                            <td><strong>@lesson.Title</strong></td>
                            <td>@lesson.Order</td>
                            <td>@lesson.Exercises?.Count / 10</td>
                            <td>@lesson.EstimatedMinutes min</td>
                            <td>
                                <span class="badge @(lesson.IsActive ? "badge-success" : "badge-danger")">
                                    @(lesson.IsActive ? "Ativo" : "Inativo")
                                </span>
                            </td>
                            <td class="actions-col">
                                <button class="btn-icon btn-edit" @onclick="() => OpenEdit(lesson)" title="Editar">✏️</button>
                                <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(lesson)" title="Excluir">🗑️</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Modal: Create/Edit Lesson -->
@if (showModal)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal modal-lg" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(isEditing ? "Editar Lição" : "Nova Lição")</h3>
                <button class="modal-close" @onclick="CloseModal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Nível</label>
                        <select class="form-control" @bind="form.LevelCode">
                            @foreach (var lvl in Levels)
                            {
                                <option value="@lvl">@lvl</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Módulo</label>
                        <select class="form-control" value="@form.ModuleId" @onchange="OnModuleChanged">
                            @foreach (var mod in Modules)
                            {
                                <option value="@mod.Id">@mod.Title</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Título</label>
                        <input class="form-control" @bind="form.Title" placeholder="Ex: Lesson 1: Greetings" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Ordem</label>
                        <input class="form-control" type="number" @bind="form.Order" min="1" max="6" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Descrição</label>
                    <textarea class="form-control form-control-textarea" @bind="form.Description" placeholder="Breve descrição da lição"></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Tempo estimado (min)</label>
                        <input class="form-control" type="number" @bind="form.EstimatedMinutes" />
                    </div>
                    <div class="form-group checkbox-group" style="align-self:flex-end">
                        <label>
                            <input type="checkbox" @bind="form.IsActive" /> Lição Ativa
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@(saving)">@(saving ? "Salvando..." : "Salvar")</button>
            </div>
        </div>
    </div>
}

<!-- Delete Confirmation -->
@if (showDeleteConfirm)
{
    <div class="modal-backdrop" @onclick="() => showDeleteConfirm = false">
        <div class="modal modal-sm" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Confirmar Exclusão</h3>
                <button class="modal-close" @onclick="() => showDeleteConfirm = false">&times;</button>
            </div>
            <div class="modal-body">
                <p>Excluir a lição <strong>"@deleteTarget?.Title"</strong>?</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancelar</button>
                <button class="btn btn-danger" @onclick="Delete">Excluir</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Lesson> lessons = new();
    private bool loading = true;
    private string? selectedLevel;

    // Modal state
    private bool showModal;
    private bool isEditing;
    private bool saving;
    private Lesson form = new();
    private string? editingId;

    // Delete confirmation
    private bool showDeleteConfirm;
    private Lesson? deleteTarget;

    // Notification
    private string? notification;
    private string? notificationType;

    // CEFR levels
    private string[] Levels => new[] { "A1", "A2", "B1", "B2", "C1", "C2" };

    private class ModuleOption { public string Id { get; set; } = ""; public string Title { get; set; } = ""; }
    private List<ModuleOption> Modules => new()
    {
        new() { Id = "m1", Title = "Module 1" },
        new() { Id = "m2", Title = "Module 2" },
        new() { Id = "m3", Title = "Module 3" },
        new() { Id = "m4", Title = "Module 4" },
    };

    protected override async Task OnInitializedAsync() => await LoadLessons();

    private async Task LoadLessons()
    {
        loading = true;
        if (!string.IsNullOrEmpty(selectedLevel))
        {
            var res = await Http.GetFromJsonAsync<List<Lesson>>($"http://localhost:5196/api/lessons/level/{selectedLevel}");
            lessons = res ?? new();
        }
        else
        {
            var res = await Http.GetFromJsonAsync<List<Lesson>>("http://localhost:5196/api/lessons");
            lessons = res ?? new();
        }
        loading = false;
    }

    private async Task OnLevelChanged(ChangeEventArgs e)
    {
        selectedLevel = e.Value?.ToString();
        await LoadLessons();
    }

    private void OpenCreate()
    {
        isEditing = false;
        editingId = null;
        form = new Lesson { IsActive = true, EstimatedMinutes = 30, LevelCode = selectedLevel ?? "A1", ModuleId = "m1", ModuleTitle = "Module 1", Order = 1 };
        showModal = true;
    }

    private void OpenEdit(Lesson lesson)
    {
        isEditing = true;
        editingId = lesson.Id;
        form = new Lesson
        {
            Id = lesson.Id,
            LevelCode = lesson.LevelCode,
            ModuleId = lesson.ModuleId,
            ModuleTitle = lesson.ModuleTitle,
            Title = lesson.Title,
            Order = lesson.Order,
            Description = lesson.Description,
            Content = lesson.Content,
            Exercises = lesson.Exercises,
            EstimatedMinutes = lesson.EstimatedMinutes,
            IsActive = lesson.IsActive
        };
        showModal = true;
    }

    private void CloseModal() { showModal = false; form = new(); }

    private async Task OnModuleChanged(ChangeEventArgs e)
    {
        form.ModuleId = e.Value?.ToString() ?? "";
        var mod = Modules.FirstOrDefault(m => m.Id == form.ModuleId);
        form.ModuleTitle = mod?.Title ?? "";
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(form.Title)) return;
        saving = true;

        var json = System.Text.Json.JsonSerializer.Serialize(form);
        var content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");
        var res = isEditing && !string.IsNullOrEmpty(editingId)
            ? await Http.PutAsync($"http://localhost:5196/api/lessons/{editingId}", content)
            : await Http.PostAsync("http://localhost:5196/api/lessons", content);

        saving = false;
        if (res.IsSuccessStatusCode)
        {
            notification = isEditing ? "Lição atualizada!" : "Lição criada!";
            notificationType = "success";
            await LoadLessons();
        }
        else
        {
            notification = $"Erro ao salvar.";
            notificationType = "error";
        }
        CloseModal();
    }

    private void ConfirmDelete(Lesson lesson) { deleteTarget = lesson; showDeleteConfirm = true; }

    private async Task Delete()
    {
        if (deleteTarget == null) return;
        var res = await Http.DeleteAsync($"http://localhost:5196/api/lessons/{deleteTarget.Id}");
        showDeleteConfirm = false;
        deleteTarget = null;

        if (res.IsSuccessStatusCode)
        {
            notification = "Lição excluída!";
            notificationType = "success";
            await LoadLessons();
        }
        else
        {
            notification = "Erro ao excluir.";
            notificationType = "error";
        }
    }
}
